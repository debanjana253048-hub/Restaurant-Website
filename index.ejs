<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Restaurant Website</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background-color: #f8f5f2;
        }

        nav {
            background-color: #3b08f5;
            padding: 15px;
            text-align: center;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin: 0 20px;
            font-size: 18px;
            font-weight: bold;
        }

        nav a:hover {
            color: #ffd700;
        }

        .hero {
            text-align: center;
            padding: 100px 20px;
        }

        .hero h1 {
            font-size: 50px;
            color: #f3f70d;
        }

        .hero p {
            font-size: 20px;
            color: #444;
            width: 70%;
            margin: auto;
            line-height: 1.8;
        }

        .btn {
            display: inline-block;
            margin-top: 30px;
            padding: 12px 25px;
            background-color: #0dcac1;
            color: white;
            text-decoration: none;
            border-radius: 5px;
            font-size: 18px;
        }

        .btn:hover {
            background-color: #dceb0e;
        }
    </style>
</head>
<body>

    <nav>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
    </nav>

    <div class="hero">
        <h1>Welcome to Our Restaurant</h1>

        <p>
            Experience delicious food, warm hospitality, and unforgettable dining moments.
            We serve freshly prepared meals made with passion and quality ingredients.
        </p>

        <a href="/about" class="btn">Learn More</a>
    </div>

</body>
</html>
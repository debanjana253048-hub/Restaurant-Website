<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background-color: #f8f5f2;
        }

        nav {
            background-color: #5805f1;
            padding: 15px;
            text-align: center;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin: 0 20px;
            font-size: 18px;
            font-weight: bold;
        }

        nav a:hover {
            color: #ffd700;
        }

        .container {
            width: 80%;
            margin: 50px auto;
            background: white;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0px 4px 10px rgba(0,0,0,0.1);
        }

        h1 {
            text-align: center;
            color: #f1ee32;
        }

        p {
            font-size: 18px;
            line-height: 1.8;
            color: #444;
        }

        .contact-info {
            margin-top: 30px;
        }
    </style>
</head>
<body>

    <nav>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
    </nav>

    <div class="container">
        <h1>Contact Us</h1>

        <p>
            We would love to hear from you! Visit our restaurant or contact us using the information below.
        </p>

        <div class="contact-info">
            <p><strong>Address:</strong> 123 Food Street, Kolkata, India</p>

            <p><strong>Phone:</strong> +91 9876543210</p>

            <p><strong>Email:</strong> contact@restaurant.com</p>

            <p><strong>Opening Hours:</strong> 10:00 AM - 11:00 PM</p>
        </div>
    </div>

</body>
</html>